	//operaciones básicas y mostrar los resultados por la pantalla de las cuatro operaciones.

	Definir A , B como entero;
	
	escribir "ingrese valor del A";
	Leer A;
	Escribir "Inggrese valor del B";
	leer B;
	
	Escribir "(" A ")+(" B ")=" (a+b);
	Escribir "(" A ")-(" B ")=" (a-b);
