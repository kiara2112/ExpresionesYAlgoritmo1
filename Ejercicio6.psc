Algoritmo Ejercicio6
	//Escribir un algoritmo que calcule la superficie de un triángulo en función de la base y altura
	//(se entiende que deben de ser ingresados). Mostrar su resultado
	Definir Base,Altura como real;
	
	Escribir "Pasame la BASE del triangulo";
	Leer Base;
	Escribir "Pasame la ALTURA del triangulo";
	Leer Altura;
	
	Escribir "el Area del triangulo es ", (Base*Altura)/2; //no es un triangulo rectangulo 
	
FinAlgoritmo
