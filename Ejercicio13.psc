Algoritmo Ejercicio13
	//Generar los números naturales del 1 al 200 e imprimir en forma secuencial aquellos mayoresa 120.
	
	Definir contarNum como entero;
	ContarNum<-120; //del 1 al 119 no va ser impreso, no tiene sentido hacer que los redenrise 
	
	Mientras ContarNum<=200 Hacer
		Escribir ContarNum;
		ContarNum<-ContarNum+1; //va sumando hasta 200
	FinMientras
	
FinAlgoritmo
